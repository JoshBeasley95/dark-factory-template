#!/bin/sh
# Dark Factory pre-commit hook
# Runs code quality eval — blocks commit on syntax errors, secrets, or broken imports.
# Does NOT run ML evals or unit tests (too slow for pre-commit).
#
# Install:
#   cp hooks/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit

REPO_DIR="$(git rev-parse --show-toplevel)"
PYTHON="${PYTHON:-python3}"

echo "[pre-commit] Running code quality checks..."

"$PYTHON" "$REPO_DIR/tests/eval_code_quality.py" --src "$REPO_DIR/src"
EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
    echo ""
    echo "[pre-commit] BLOCKED — fix code quality issues before committing."
    echo "  Run: python tests/eval_code_quality.py"
    exit 1
fi

echo "[pre-commit] Passed."
exit 0
